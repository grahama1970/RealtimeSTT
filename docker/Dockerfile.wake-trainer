FROM nvidia/cuda:12.8.1-cudnn-devel-ubuntu24.04

ARG OPENWAKEWORD_COMMIT=368c03716d1e92591906a84949bc477f3a834455
ARG PIPER_SAMPLE_GENERATOR_COMMIT=f1988a4d54eddb23d99e86f0adfef6226a85acc7
ARG PIPER_LIBRITTS_MODEL_URL=https://github.com/rhasspy/piper-sample-generator/releases/download/v1.0.0/en-us-libritts-high.pt
ARG PIPER_LIBRITTS_MODEL_SHA256=5258f21adf77c29248d9a89d51ca9492f6e75a498140584dcbed0edcab81960a
ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    OPENWAKEWORD_ROOT=/opt/openWakeWord \
    PIPER_SAMPLE_GENERATOR_ROOT=/opt/piper-sample-generator

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-dev python3-pip git curl ca-certificates \
    build-essential ffmpeg libsndfile1 libespeak-ng1 espeak-ng && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /workspace
COPY scripts/wake_training/requirements.lock /tmp/requirements.lock
RUN python3 -m pip install --break-system-packages --no-cache-dir \
      torch==2.8.0+cu128 torchaudio==2.8.0+cu128 \
      --index-url https://download.pytorch.org/whl/cu128 && \
    python3 -m pip install --break-system-packages --no-cache-dir -r /tmp/requirements.lock

RUN git clone https://github.com/dscripka/openWakeWord.git /opt/openWakeWord && \
    git -C /opt/openWakeWord checkout "$OPENWAKEWORD_COMMIT" && \
    test "$(git -C /opt/openWakeWord rev-parse HEAD)" = "$OPENWAKEWORD_COMMIT" && \
    git clone https://github.com/dscripka/piper-sample-generator.git /opt/piper-sample-generator && \
    git -C /opt/piper-sample-generator checkout "$PIPER_SAMPLE_GENERATOR_COMMIT" && \
    test "$(git -C /opt/piper-sample-generator rev-parse HEAD)" = "$PIPER_SAMPLE_GENERATOR_COMMIT" && \
    python3 -m pip install --break-system-packages --no-cache-dir --no-deps -e /opt/openWakeWord

RUN test "$(printf '%s' "$PIPER_LIBRITTS_MODEL_SHA256" | grep -Ec '^[0-9a-f]{64}$')" -eq 1 && \
    mkdir -p /opt/piper-sample-generator/models && \
    curl -fsSL "$PIPER_LIBRITTS_MODEL_URL" \
      -o /opt/piper-sample-generator/models/en-us-libritts-high.pt && \
    printf '%s  %s\n' "$PIPER_LIBRITTS_MODEL_SHA256" \
      /opt/piper-sample-generator/models/en-us-libritts-high.pt | sha256sum -c -

ENV PIPER_LIBRITTS_MODEL=/opt/piper-sample-generator/models/en-us-libritts-high.pt \
    PIPER_LIBRITTS_MODEL_SHA256=5258f21adf77c29248d9a89d51ca9492f6e75a498140584dcbed0edcab81960a

ARG OPENWAKEWORD_COMPAT_PATCH_SHA256=13618f9cdf97f0da4cd47539409a8166452873ba5435b9b869da6976a49e08f9
COPY docker/patches/openwakeword-368c-argparse-defaults.patch /tmp/openwakeword-argparse-defaults.patch
RUN test "$(git -C /opt/openWakeWord rev-parse HEAD)" = "$OPENWAKEWORD_COMMIT" && \
    echo "$OPENWAKEWORD_COMPAT_PATCH_SHA256  /tmp/openwakeword-argparse-defaults.patch" | sha256sum -c - && \
    sed -i 's/\r$//' /opt/openWakeWord/openwakeword/train.py && \
    git -C /opt/openWakeWord apply --check /tmp/openwakeword-argparse-defaults.patch && \
    git -C /opt/openWakeWord apply /tmp/openwakeword-argparse-defaults.patch && \
    test "$(grep -c 'default=\"False\"' /opt/openWakeWord/openwakeword/train.py)" -eq 0

# Pin the feature backbone used by the official v0.5.1/v0.6.0 training flow.
RUN mkdir -p /opt/openWakeWord/openwakeword/resources/models && \
    curl -fsSL https://github.com/dscripka/openWakeWord/releases/download/v0.5.1/embedding_model.onnx \
      -o /opt/openWakeWord/openwakeword/resources/models/embedding_model.onnx && \
    echo '70d164290c1d095d1d4ee149bc5e00543250a7316b59f31d056cff7bd3075c1f  /opt/openWakeWord/openwakeword/resources/models/embedding_model.onnx' | sha256sum -c - && \
    curl -fsSL https://github.com/dscripka/openWakeWord/releases/download/v0.5.1/melspectrogram.onnx \
      -o /opt/openWakeWord/openwakeword/resources/models/melspectrogram.onnx && \
    echo 'ba2b0e0f8b7b875369a2c89cb13360ff53bac436f2895cced9f479fa65eb176f  /opt/openWakeWord/openwakeword/resources/models/melspectrogram.onnx' | sha256sum -c -

COPY scripts/wake_training /workspace/scripts/wake_training
RUN python3 -m compileall -q /workspace/scripts/wake_training && \
    python3 - <<'PY'
import platform, scipy, torch
assert platform.python_version().startswith('3.12.'), platform.python_version()
assert scipy.__version__ == '1.14.1', scipy.__version__
assert torch.__version__ == '2.8.0+cu128', torch.__version__
PY

CMD ["bash"]
